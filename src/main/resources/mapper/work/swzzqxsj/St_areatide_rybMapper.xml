    <select id="selecttb_wind_informationListtTop" resultType="swzzmodeserver.workserver.pojo.swzzrtsq.tb_wind_informationPojo">
        select  top 2000 *  from  HPJSQ.tb_wind_information
        <where>
            <if test="stime != null and stime != ''">
                <![CDATA[ and dt_time >#{stime}  ]]>
            </if>
            <if test="etime != null and etime != ''">
                <![CDATA[ and dt_time <=#{etime} ]]>
            </if>
            <if test="stcdList != null and stcdList.size() > 0">
                and  st_stationid  in
                <foreach collection="stcdList" open="(" close=")" item="stcd" separator=",">
                    #{stcd}
                </foreach>
            </if>
        </where>
        <![CDATA[ and nm_speed >=0  ]]>
        order by dt_time asc
