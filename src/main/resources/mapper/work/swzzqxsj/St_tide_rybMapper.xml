    <select id="selectListByNew" resultType="swzzmodeserver.workserver.pojo.swzzqxsj.St_tide_rybPojo">
        select a.* from "st_tide_ryb" a inner join(
        SELECT MAX(YBTM) as MYBTM, TM, STCD FROM "st_tide_ryb"
        where
        <![CDATA[ YBTM <= #{etime,jdbcType=VARCHAR} ]]>
        <![CDATA[and YBTM >= #{stime,jdbcType=VARCHAR} ]]>
        and STCD = #{ID}
        GROUP BY STCD, TM
        ) b on a.STCD = b.STCD and a.YBTM = MYBTM AND A.TM = B.TM
        order by a.YBTM,a.TM desc
    </select>


    <select id="selectListByNewFirst" resultType="swzzmodeserver.workserver.pojo.swzzqxsj.St_tide_rybPojo">
        select a.* from "st_tide_ryb" a inner join(
            SELECT  MAX(YBTM) as MYBTM, STCD FROM "st_tide_ryb"
            where
        <![CDATA[ YBTM <=to_date( #{etime,jdbcType=VARCHAR},'yyyy-MM-dd hh24:mi:ss') ]]>
        <![CDATA[and YBTM >= to_date(#{stime,jdbcType=VARCHAR} ,'yyyy-MM-dd hh24:mi:ss')]]>
        <if test="ID != null and ID.size() > 0">
            and STCD in
            <foreach collection="ID" open="(" close=")" item="id" separator=",">
                #{id,jdbcType=VARCHAR}
            </foreach>
        </if>
            GROUP BY STCD, YBTM
        ) b on a.STCD = b.STCD and a.YBTM = MYBTM
        <![CDATA[and a.TM > to_date(#{etime,jdbcType=VARCHAR},'yyyy-MM-dd hh24:mi:ss') ]]>
        order by a.TM asc
    </select>

