    <select id="selectListMax" resultType="swzzmodeserver.workserver.pojo.swzzqxsj.Tz_watersheddataPojo">
        SELECT
            w.*,
            ROUND(sub.total_drp,1) AS DRP,
            sub.RLSTM
        FROM "TZ_WATERSHED" w
                 INNER JOIN (
            SELECT
                KEYID,
                total_drp,
                RLSTM,
                ROW_NUMBER() OVER (PARTITION BY KEYID ORDER BY RLSTM DESC) as rn
            FROM (
                     SELECT
                         KEYID,
                         RLSTM,
                         SUM(drp) as total_drp
                     FROM "TZ_WATERSHEDDATA"

                    <where>
                        <if test="stime != null and stime != ''">
                            <![CDATA[ and RLSTM >= #{stime} ]]>
                        </if>
                        <if test="pathname != null and pathname != ''">
                            and FPDR =  #{pathname}
                        </if>
                    </where>

                     GROUP BY KEYID, RLSTM
                 ) aggregated_data
        ) sub ON w."KEYID" = sub."KEYID"
        WHERE sub.rn = 1;
    </select>

    <select id="selectListLast" resultType="swzzmodeserver.workserver.pojo.swzzqxsj.Tz_watersheddataPojo">
        SELECT
        FTM,
        round(AVG(DRP),1) AS DRP,
        MAX(RLSTM) as  RLSTM
        FROM (
        SELECT
        FTM,
        DRP,
        ROW_NUMBER() OVER(PARTITION BY KEYID, FTM ORDER BY RLSTM DESC) as rn,
        RLSTM
        FROM
        "tz_watersheddata"

        <where>
            <if test="pathname != null and pathname != ''">
                and TYPE = #{pathname}
            </if>
            <if test="stime != null and stime != ''">
                <![CDATA[ and FTM >= #{stime} ]]>
            </if>
            <if test="etime != null and etime != ''">
                <![CDATA[ and FTM <= #{etime} ]]>
            </if>
            <if test="fpdr != null and fpdr.size() > 0">
                and FPDR in
                <foreach collection="fpdr" open="(" close=")" item="item" separator=",">
                    #{item}
                </foreach>
            </if>
        </where>

        ) t
        WHERE
        t.rn = 1
        GROUP BY
        FTM
        ORDER BY
        FTM;
    </select>

