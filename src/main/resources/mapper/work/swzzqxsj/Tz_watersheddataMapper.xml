             </if>
         </where>
        order by FTM -->


        SELECT *
        FROM (
            SELECT *, 
                MAX(RLSTM) OVER (PARTITION BY FPDR) as max_rlstm 
            FROM "tz_watersheddata"
            WHERE TYPE = '上海气象台' 
            <if test="fpdr != null and fpdr.size() > 0">
                 and FPDR in
                 <foreach collection="fpdr" open="(" close=")" item="item" separator=",">
                     #{item}
                 </foreach>
             </if>
            <if test="rlstime != null and rlstime != ''">
                 <![CDATA[ and RLSTM >= #{rlstime} ]]>
             </if>
             <if test="rletime != null and rletime != ''">
                 <![CDATA[ and RLSTM <= #{rletime} ]]>
             </if>
        ) t
        WHERE RLSTM = max_rlstm 
        ORDER BY FTM;
    </select>

