<?xml version="1.0" encoding="UTF-8" ?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN" "http://mybatis.org/dtd/mybatis-3-mapper.dtd" >
<mapper namespace="swzzmodeserver.workserver.data.swzzwater.ST_GATE_RNEWData">
    <select id="selectList" resultType="swzzmodeserver.workserver.pojo.swzzwater.ST_GATE_RNEWPojo">
        select * from ST_GATE_RNEW
        <where>
            <if test="stime != null and stime != ''">
                <![CDATA[ and TM >= #{stime} ]]>
            </if>
            <if test="etime != null and etime != ''">
                <![CDATA[ and TM <= #{etime} ]]>
            </if>
<!--            <if test="stcdList != null and stcdList.size() > 0">-->
<!--                and STCD in-->
<!--                <foreach collection="stcdList" open="(" close=")" item="stcd" separator=",">-->
<!--                    #{stcd}-->
<!--                </foreach>-->
<!--            </if>-->
        </where>
        order by TM desc
    </select>
</mapper>