            <!--            <if test="type != null">-->
            <!--                and GROUPID in-->
            <!--                <foreach collection="type" open="(" close=")" item="item" separator=",">-->
            <!--                    #{item}-->
            <!--                </foreach>-->
            <!--            </if>-->
        </where>
    </select>

    <insert id="insertOne" parameterType="swzzmodeserver.workserver.pojo.swzzdata.MyiconPojo">
        insert into "myicon"
        <trim prefix="(" suffix=")" suffixOverrides=",">
            <if test="ID != null and ID != ''">
                ID,
            </if>
            <if test="CLASSNAME != null and CLASSNAME != ''">
                CLASSNAME,
            </if>
        </trim>
        values
        <trim prefix="(" suffix=")" suffixOverrides=",">
            <if test="ID != null and ID != ''">
                #{ID},
            </if>
            <if test="CLASSNAME != null and CLASSNAME != ''">
                #{CLASSNAME},
            </if>
        </trim>
    </insert>

    <update id="updateOne" parameterType="swzzmodeserver.workserver.pojo.swzzdata.MyiconPojo">
        update "myicon"
        <set>
            <if test="CLASSNAME != null and CLASSNAME != ''">
                CLASSNAME = #{CLASSNAME},
            </if>
        </set>
        where ID = #{ID}
    </update>
    <delete id="deleteOne">
        delete from "myicon" where ID = #{ID}
    </delete>
</mapper>