<?xml version="1.0" encoding="UTF-8" ?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN" "http://mybatis.org/dtd/mybatis-3-mapper.dtd" >
<mapper namespace="swzzmodeserver.workserver.data.swzzdata.Qx_enableData">
    <select id="selectList" resultType="swzzmodeserver.workserver.pojo.swzzdata.Qx_enablePojo">
        select a.* from "qx_enable" a
        <where>
            <if test="ID != null and ID != ''">
                and QX_ID = #{ID}
            </if>
            <if test="type != null and type.size() > 0">
                and QX_ID in
                <foreach collection="type" open="(" close=")" item="item" separator=",">
                    #{item}
                </foreach>
            </if>
        </where>
        <if test="startindex != null and pagesize != null">
            limit #{startindex},#{pagesize}
        </if>
    </select>

    <select id="selectCount" resultType="integer">
        SELECT count(1) FROM "qx_enable"
