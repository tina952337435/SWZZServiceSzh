        </where>
    </select>

    <insert id="insertOne" parameterType="swzzmodeserver.workserver.pojo.swzzdata.Qx_enablePojo">
        insert into "qx_enable"
        <trim prefix="(" suffix=")" suffixOverrides=",">
            <if test="ID != null and ID != ''">
                ID,
            </if>
            <if test="QX_ID != null and QX_ID != ''">
                QX_ID,
            </if>
            <if test="QX_MOKUAI != null and QX_MOKUAI != ''">
                QX_MOKUAI,
            </if>
            <if test="MANAGEMENT != null and MANAGEMENT != ''">
                MANAGEMENT,
            </if>
            <if test="ISCHAXUN != null and ISCHAXUN != ''">
                ISCHAXUN,
            </if>
        </trim>
        values
        <trim prefix="(" suffix=")" suffixOverrides=",">
            <if test="ID != null and ID != ''">
                #{ID},
            </if>
            <if test="QX_ID != null and QX_ID != ''">
                #{QX_ID},
            </if>
            <if test="QX_MOKUAI != null and QX_MOKUAI != ''">
                #{QX_MOKUAI},
            </if>
            <if test="MANAGEMENT != null and MANAGEMENT != ''">
                #{MANAGEMENT},
            </if>
            <if test="ISCHAXUN != null and ISCHAXUN != ''">
                #{ISCHAXUN},
            </if>
        </trim>
    </insert>

    <update id="updateOne" parameterType="swzzmodeserver.workserver.pojo.swzzdata.Qx_enablePojo">
        update "qx_enable"
        <set>
            <if test="QX_ID != null and QX_ID != ''">
                QX_ID = #{QX_ID},
            </if>
            <if test="QX_MOKUAI != null and QX_MOKUAI != ''">
                QX_MOKUAI = #{QX_MOKUAI},
            </if>
            <if test="MANAGEMENT != null and MANAGEMENT != ''">
                MANAGEMENT = #{MANAGEMENT},
            </if>
            <if test="ISCHAXUN != null and ISCHAXUN != ''">
                ISCHAXUN = #{ISCHAXUN},
            </if>
        </set>
        where ID = #{ID}
    </update>
    <delete id="deleteOne">
        delete from "qx_enable" where QX_ID = #{ID}
    </delete>

    <insert id="instertAll" parameterType="list">
        insert into "qx_enable"(
            ID,
            QX_ID,
            QX_MOKUAI,
            MANAGEMENT,
            ISCHAXUN
            ) values
        <foreach collection="QxobjList" item="obj" separator=",">
            (
            #{obj.ID,jdbcType=VARCHAR},
            #{obj.QX_ID,jdbcType=VARCHAR},
            #{obj.QX_MOKUAI,jdbcType=VARCHAR},
            #{obj.MANAGEMENT,jdbcType=VARCHAR},
            #{obj.ISCHAXUN,jdbcType=VARCHAR}
            )
        </foreach>
    </insert>

    <update id="updateAll" parameterType="list">
        <foreach collection="QxobjList" item="obj" separator=";">
            update "qx_enable"
            <set>
                <if test="obj.QX_ID != null and obj.QX_ID != ''">
                    QX_ID = #{obj.QX_ID,jdbcType=VARCHAR},
                </if>
                <if test="obj.QX_MOKUAI != null and obj.QX_MOKUAI != ''">
                    QX_MOKUAI = #{obj.QX_MOKUAI,jdbcType=VARCHAR},
                </if>
                <if test="obj.MANAGEMENT != null and obj.MANAGEMENT != ''">
                    MANAGEMENT = #{obj.MANAGEMENT,jdbcType=VARCHAR},
                </if>
                <if test="obj.ISCHAXUN != null and obj.ISCHAXUN != ''">
                    ISCHAXUN = #{obj.ISCHAXUN,jdbcType=VARCHAR},
                </if>
            </set>
            where ID = #{obj.ID,jdbcType=VARCHAR}
        </foreach>
    </update>
</mapper>