    <insert id="insertOne" parameterType="swzzmodeserver.workserver.pojo.swzzdata.Qx_groupPojo">
        insert into "qx_group"
        <trim prefix="(" suffix=")" suffixOverrides=",">
            <if test="QX_ID != null and QX_ID != ''">
                QX_ID,
            </if>
            <if test="QX_NAME != null and QX_NAME != ''">
                QX_NAME,
            </if>
            <if test="QX_NOTE != null and QX_NOTE != ''">
                QX_NOTE,
            </if>
        </trim>
        values
        <trim prefix="(" suffix=")" suffixOverrides=",">
            <if test="QX_ID != null and QX_ID != ''">
                #{QX_ID},
            </if>
            <if test="QX_NAME != null and QX_NAME != ''">
                #{QX_NAME},
            </if>
            <if test="QX_NOTE != null and QX_NOTE != ''">
                #{QX_NOTE},
            </if>
        </trim>
    </insert>

    <update id="updateOne" parameterType="swzzmodeserver.workserver.pojo.swzzdata.Qx_groupPojo">
        update "qx_group"
        <set>
            <if test="QX_NAME != null and QX_NAME != ''">
                QX_NAME = #{QX_NAME},
            </if>
            <if test="QX_NOTE != null and QX_NOTE != ''">
                QX_NOTE = #{QX_NOTE},
            </if>
        </set>
        where QX_ID = #{QX_ID}
    </update>
    <delete id="deleteOne">
        delete from "qx_group" where QX_ID = #{ID}
    </delete>

