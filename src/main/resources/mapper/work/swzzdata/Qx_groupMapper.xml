    <select id="selectList" resultType="swzzmodeserver.workserver.pojo.swzzdata.Qx_groupPojo">
        select a.* from "qx_group" a
        <where>

            <if test="ID != null and ID != ''">
                and QX_ID = #{ID}
            </if>
            <if test="key != null and key != ''">
                and (
                QX_NAME like concat('%',concat(#{key},'%'))
                or QX_NOTE like concat('%',concat(#{key},'%'))
                )
