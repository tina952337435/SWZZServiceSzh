<?xml version="1.0" encoding="UTF-8" ?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN" "http://mybatis.org/dtd/mybatis-3-mapper.dtd" >
<mapper namespace="swzzmodeserver.workserver.data.swzzrtsq.RTSQST_GATE_RData">
    <select id="selectByNew" resultType="swzzmodeserver.workserver.pojo.swzzrtsq.ST_GATE_RPojo">
         select * from ST_GATE_R
         <where>
             <if test="STCD != null and STCD != ''">
                 and STCD = #{STCD}
             </if>
         </where>
    </select>
    <select id="selectGateListNew" resultType="swzzmodeserver.workserver.pojo.swzzrtsq.ST_GATE_RPojo">
        select * from ST_GATE_R
        <where>
            <if test="stcdList != null and stcdList.size() > 0">
                and STCD in
                <foreach collection="stcdList" open="(" close=")" item="stcd" separator=",">
                    #{stcd}
                </foreach>
            </if>
        </where>
    </select>
    <select id="selectByHis" resultType="swzzmodeserver.workserver.pojo.swzzrtsq.ST_GATE_RPojo">
        select * from ST_GATE_R
        <where>
            <if test="STCD != null and STCD != ''">
                and STCD = #{STCD}
            </if>
            <if test="stime != null and stime != ''">
                <![CDATA[ and TM >= to_date(#{stime},'YYYY-MM-DD HH24:MI:SS') ]]>
            </if>
            <if test="etime != null and etime != ''">
                <![CDATA[ and TM <= to_date(#{etime},'YYYY-MM-DD HH24:MI:SS') ]]>
            </if>
        </where>
    </select>
    <insert id="insertAll" parameterType="swzzmodeserver.workserver.pojo.swzzrtsq.ST_GATE_RPojo">
        insert into ST_GATE_R(STCD,TM,EXKEY,EQPTP,EQPNO,GTQ,GTOPNUM,GTOPHGT,MSQMT,TYPE) values
        <foreach collection="quPojo" item="pojo" separator=",">
            (#{pojo.STCD},#{pojo.TM},#{pojo.EXKEY},#{pojo.EQPTP},#{pojo.EQPNO},#{pojo.GTQ},
            #{pojo.GTOPNUM},#{pojo.GTOPHGT},#{pojo.MSQMT},#{pojo.TYPE})
        </foreach>
    </insert>

    <select id="queryList" resultType="swzzmodeserver.workserver.pojo.swzzrtsq.ST_GATE_RPojo">
        select * from ST_GATE_RLIST
        <where>
            <if test="listSTCD != null and listSTCD.size() > 0">
                and STCD in
                <foreach collection="listSTCD" open="(" close=")" item="stcd" separator=",">
                    #{stcd}
                </foreach>
            </if>
            <if test="exkey != null and exkey != ''">
                and exkey = #{exkey}
            </if>
            <if test="eqptp != null and eqptp != ''">
                and eqptp = #{eqptp}
            </if>
            <if test="stime != null and stime != ''">
                <![CDATA[ and TM >= to_date(#{stime},'YYYY-MM-DD HH24:MI:SS') ]]>
            </if>
            <if test="etime != null and etime != ''">
                <![CDATA[ and TM <= to_date(#{etime},'YYYY-MM-DD HH24:MI:SS') ]]>
            </if>
            order by tm asc
        </where>
    </select>

    <select id="queryListQ" resultType="swzzmodeserver.workserver.pojo.swzzrtsq.ST_GATE_RPojo">
        select * from ST_GATE_RLISTQ
        <where>
            <if test="listSTCD != null and listSTCD.size() > 0">
                and STCD in
                <foreach collection="listSTCD" open="(" close=")" item="stcd" separator=",">
                    #{stcd}
                </foreach>
            </if>
            <if test="exkey != null and exkey != ''">
                and exkey = #{exkey}
            </if>
            <if test="eqptp != null and eqptp != ''">
                and eqptp = #{eqptp}
            </if>
            <if test="stime != null and stime != ''">
                <![CDATA[ and TM >= to_date(#{stime},'YYYY-MM-DD HH24:MI:SS') ]]>
            </if>
            <if test="etime != null and etime != ''">
                <![CDATA[ and TM <= to_date(#{etime},'YYYY-MM-DD HH24:MI:SS') ]]>
            </if>
            order by tm asc
        </where>
    </select>


    <select id="queryGateBList" resultType="swzzmodeserver.workserver.pojo.swzzrtsq.ST_GATE_BPojo">
        select * from ST_GATE_B
        <where>
            <if test="listSTCD != null and listSTCD.size() > 0">
                and STCD in
                <foreach collection="listSTCD" open="(" close=")" item="stcd" separator=",">
                    #{stcd}
                </foreach>
            </if>
        </where>
    </select>
    <select id="queryGateBListByType" resultType="swzzmodeserver.workserver.pojo.swzzrtsq.ST_GATE_BPojo">
        select * from ST_GATE_B
        <where>
            <if test="listSTCD != null and listSTCD.size() > 0">
                and STCD in
                <foreach collection="listSTCD" open="(" close=")" item="stcd" separator=",">
                    #{stcd}
                </foreach>
            </if>
            <if test="mtype != null and mtype != ''">
                and mtype = #{mtype}
            </if>
        </where>
    </select>

    <select id="selectNewList" resultType="swzzmodeserver.workserver.pojo.swzzrtsq.ST_GATE_RPojo">
        select a.* from ST_GATE_R a inner join (
            select MAX(TM) TM,STCD,EXKEY,EQPNO,EQPTP from ST_GATE_R group by STCD,EXKEY,EQPNO,EQPTP
        ) b on a.STCD = b.STCD and a.EXKEY = b.EXKEY and a.EQPNO = b.EQPNO and a.EQPTP = b.EQPTP and a.TM = b.TM
    </select>
    <select id="selectNewListByStcd" resultType="swzzmodeserver.workserver.pojo.swzzrtsq.ST_GATE_RPojo">
        select a.* from ST_GATE_R a inner join (
            select MAX(TM) TM,STCD,EXKEY,EQPNO,EQPTP from ST_GATE_R where STCD = #{stcd} group by STCD,EXKEY,EQPNO,EQPTP
        ) b on a.STCD = b.STCD and a.EXKEY = b.EXKEY and a.EQPNO = b.EQPNO and a.EQPTP = b.EQPTP and a.TM = b.TM
    </select>
</mapper>