    <update id="upDateOne" parameterType="swzzmodeserver.workserver.pojo.swzzrtsq.ST_WDPSTAT_RPojo">
        update ST_WDPSTAT_R
        <set>
<!--            <if test="STCD != null and STCD != ''">-->
<!--                #{STCD},-->
<!--            </if>-->
            <if test="IDTM != null and IDTM != ''">
                IDTM = #{IDTM},
            </if>
            <if test="STTDRCD != null and STTDRCD != ''">
                STTDRCD = #{STTDRCD},
            </if>
            <if test="PPTMS != null">
                PPTMS = #{PPTMS},
            </if>
            <if test="ACCPW != null">
