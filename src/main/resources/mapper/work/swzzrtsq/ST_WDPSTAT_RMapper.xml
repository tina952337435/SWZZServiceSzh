    <select id="selectGQDAYList" resultType="swzzmodeserver.workserver.pojo.swzzrtsq.ST_WDPSTAT_RPojo">
        select stcd,count(*)*15*60*insflow/10000 ACCDW,to_char(TM,'YYYY-MM-DD') IDTM from "SZ_WATER"."ST_GATE_RLIST"
        <where>
            eqptp='泵站状态' and gtq=1
            <if test="STIME!='' and STIME!=null">
                and tm>=to_date(#{STIME},'YYYY-MM-DD HH24:MI:SS')
            </if>
            <if test="ETIME!='' and ETIME!=null">
                <![CDATA[ and tm<=to_date(#{ETIME},'YYYY-MM-DD HH24:MI:SS')]]>
            </if>
            <if test="listSTCD != null and listSTCD.size() > 0 ">
                and stcd in
                <foreach collection="listSTCD" close=")" open="(" item="item" separator=",">
                    '${item}'
                </foreach>
            </if>
        </where>
        group by stcd,to_char(TM,'YYYY-MM-DD')
    </select>
    <select id="selectGQHOURList" resultType="swzzmodeserver.workserver.pojo.swzzrtsq.ST_WDPSTAT_RPojo">
        select stcd,count(*)*15*60*insflow/10000 ACCDW,to_char(TM,'YYYY-MM-DD HH')||':00:00' IDTM from "SZ_WATER"."ST_GATE_RLIST"
        <where>
            eqptp='泵站状态' and gtq=1
            <if test="STIME!='' and STIME!=null">
                and tm>=to_date(#{STIME},'YYYY-MM-DD HH24:MI:SS')
            </if>
            <if test="ETIME!='' and ETIME!=null">
                <![CDATA[ and tm<=to_date(#{ETIME},'YYYY-MM-DD HH24:MI:SS')]]>
            </if>
            <if test="listSTCD != null and listSTCD.size() > 0 ">
                and stcd in
                <foreach collection="listSTCD" close=")" open="(" item="item" separator=",">
                    '${item}'
                </foreach>
            </if>
        </where>
        group by stcd,to_char(TM,'YYYY-MM-DD HH')
    </select>

    <select id="INOUTWDPSTATDAYSel" resultType="swzzmodeserver.workserver.pojo.swzzrtsq.INOUTWDPSTATPojo">
        select * from INOUTWDPSTAT
        <where>
            <if test="STIME!='' and STIME!=null">
                and tm>=to_date(#{STIME},'YYYY-MM-DD HH24:MI:SS')
            </if>
            <if test="ETIME!='' and ETIME!=null">
                <![CDATA[ and tm<=to_date(#{ETIME},'YYYY-MM-DD HH24:MI:SS')]]>
            </if>
            <if test="listSTCD != null and listSTCD.size() > 0 ">
                and stcd in
                <foreach collection="listSTCD" close=")" open="(" item="item" separator=",">
                    '${item}'
                </foreach>
            </if>
            <if test="PATHNAME != null and PATHNAME !=''">
                and PATHNAME  = #{PATHNAME}
            </if>
            <if test="RVNM != null and RVNM !=''">
                and RVNM  = #{RVNM}
            </if>
        </where>
        ORDER BY TM DESC
    </select>


</mapper>