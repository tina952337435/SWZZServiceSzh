    <select id="selectWdpstatRBXList" resultType="swzzmodeserver.workserver.pojo.swzzrtsq.ST_WDPSTAT_RPojo">
        select stcd,to_char(idtm-1,'yyyy-MM-dd HH24:MI:SS') idtm,ACCPW,PPHRS,ACCDW,DRNHRS from ST_WDPSTAT_BX_RLIST
        <where>
            sttdrcd='1'
            <if test="idList != null and idList.size() > 0">
                and STCD in
                <foreach collection="idList" open="(" close=")" item="id" separator=",">
                    #{id}
                </foreach>
            </if>
            <if test="stime != null and stime != ''">
                <![CDATA[ and to_char(idtm-1,'YYYY-MM-DD HH24:MI:SS')>=#{stime}]]>
            </if>
            <if test="etime != null and etime != ''">
                <![CDATA[ and to_char(idtm-1,'yyyy-MM-dd HH24:MI:SS')<=#{etime} ]]>
            </if>
        </where>
    </select>

    <select id="selectWdpstatRList" resultType="swzzmodeserver.workserver.pojo.swzzrtsq.ST_WDPSTAT_RPojo">
