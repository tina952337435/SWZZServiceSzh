    <!--   修正版：STAT_DATE表示统计周期结束时间（次日8点）-->
    <select id="selectListDayly" resultType="swzzmodeserver.workserver.pojo.swzzrtsq.ST_PSTAT_RPojo">
        SELECT
        STCD,
        CASE
        WHEN DATEPART(HOUR, IDTM) >8 THEN CONVERT(VARCHAR(10), DATEADD(DAY, 1, IDTM), 120)
        ELSE CONVERT(VARCHAR(10), IDTM, 120)
        END + ' 08:00:00' AS IDTM,
        SUM(ACCP) AS ACCP,
        '1' as STTDRCD
        FROM
        ST_PSTAT_R
        <where>
            <if test="stime != null and stime != ''">
                <![CDATA[ and IDTM > #{stime} ]]>
            </if>
            <if test="etime != null and etime != ''">
                <![CDATA[ and IDTM <= #{etime} ]]>
            </if>
            <if test="stcdList != null and stcdList.size() > 0">
                and STCD in
                <foreach collection="stcdList" open="(" close=")" item="stcd" separator=",">
                    #{stcd}
                </foreach>
            </if>
            <if test="pathname != null and pathname.size() > 0">
                and STTDRCD in
                <foreach collection="pathname" open="(" close=")" item="type" separator=",">
                    #{type}
                </foreach>
            </if>
        </where>
        GROUP BY
        STCD,
        CASE
        WHEN DATEPART(HOUR, IDTM) >8 THEN CONVERT(VARCHAR(10), DATEADD(DAY, 1, IDTM), 120)
        ELSE CONVERT(VARCHAR(10), IDTM, 120)
        END
        ORDER BY
        IDTM, STCD;
    </select>

    <update id="upDateOne" parameterType="swzzmodeserver.workserver.pojo.swzzrtsq.ST_PSTAT_RPojo">
        update ST_PSTAT_R
        <set>
            <if test="ACCP != null">
                ACCP= #{ACCP},
            </if>
            <if test="WTH != null and WTH != ''">
                WTH= #{WTH}
            </if>
        </set>
        where STCD = #{STCD} and IDTM= #{IDTM} and STTDRCD=#{STTDRCD}
    </update>

    <update id="updateALL" parameterType="list">
        <foreach collection="objList" item="obj" separator=";">
            update ST_PSTAT_R
            <set>
                <if test="obj.ACCP!=null">
                    ACCP=#{obj.ACCP},
                </if>
                <if test="obj.WTH != null and obj.WTH != ''">
                    WTH= #{obj.WTH}
                </if>
            </set>
            where STCD = #{obj.STCD} and IDTM= #{obj.IDTM} and STTDRCD=#{obj.STTDRCD}
        </foreach>
    </update>
    
    <insert id="insertAll" parameterType="swzzmodeserver.workserver.pojo.swzzrtsq.ST_PSTAT_RPojo">
        insert into ST_PSTAT_R(STCD,IDTM,STTDRCD,ACCP) values
        <foreach collection="quPojo" item="pojo" separator=",">
            (#{pojo.STCD},#{pojo.IDTM},#{pojo.STTDRCD},#{pojo.ACCP})
        </foreach>
    </insert>

    <insert id="insertOne" parameterType="swzzmodeserver.workserver.pojo.swzzrtsq.ST_PSTAT_RPojo">
        insert into ST_PSTAT_R
        <trim prefix="(" suffix=")" suffixOverrides=",">
            <if test="STCD != null and STCD != ''">
                STCD,
            </if>
            <if test="IDTM != null and IDTM != ''">
                IDTM,
            </if>
            <if test="STTDRCD != null and STTDRCD != ''">
