<mapper namespace="swzzmodeserver.workserver.data.swzzrtsq.ST_PSTAT_RData">
    <select id="selectList" resultType="swzzmodeserver.workserver.pojo.swzzrtsq.ST_PSTAT_RPojo">
        select   STCD,
        CONVERT(varchar(19), IDTM,120) as IDTM,
        STTDRCD,
        ACCP,
        WTH
        from ST_PSTAT_R
        <where>
            <if test="stime != null and stime != ''">
                <![CDATA[ and  IDTM >= #{stime} ]]>
            </if>
            <if test="etime != null and etime != ''">
                <![CDATA[ and IDTM <= #{etime} ]]>
            </if>
            <if test="stcdList != null and stcdList.size() > 0">
                and ST_PSTAT_R.STCD in
                <foreach collection="stcdList" open="(" close=")" item="stcd" separator=",">
                    #{stcd}
                </foreach>
            </if>
            <if test="pathname != null and pathname.size() > 0">
                and ST_PSTAT_R.STTDRCD in
                <foreach collection="pathname" open="(" close=")" item="type" separator=",">
                    #{type}
                </foreach>
            </if>
        </where>
        order by  IDTM asc
    </select>

