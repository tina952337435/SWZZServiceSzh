<?xml version="1.0" encoding="UTF-8" ?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN" "http://mybatis.org/dtd/mybatis-3-mapper.dtd" >
<mapper namespace="swzzmodeserver.workserver.data.swzzmode.SDE_AREAData">
    <select id="selectList" resultType="swzzmodeserver.workserver.pojo.swzzmode.SDE_AREAPojo">
        select a.* from SDE_AREA a
        <where>
            <if test="ID != null">
                and FID = #{ID}
            </if>

        </where>
        <if test="startindex != null and pagesize != null">
            limit #{startindex},#{pagesize}
        </if>
    </select>
    <select id="selectCount" resultType="java.lang.Integer">
        SELECT count(1) FROM SDE_AREA
        <where>
            <if test="ID != null">
                and FID = #{ID}
            </if>
        </where>
    </select>

    <insert id="insertOne" parameterType="swzzmodeserver.workserver.pojo.swzzmode.SDE_AREAPojo">
 --       SET IDENTITY_INSERT SDE_AREA ON
        insert into SDE_AREA
        <trim prefix="(" suffix=")" suffixOverrides=",">
            <if test="FID != null">
                FID,
            </if>
            <if test="AREANAME != null and AREANAME != ''">
                AREANAME,
            </if>
            <if test="AREAMEASURE != null">
                AREAMEASURE,
            </if>
            <if test="COLOR != null">
                COLOR,
            </if>
            <if test="ZVALUE != null">
                ZVALUE,
            </if>
        </trim>
        values
        <trim prefix="(" suffix=")" suffixOverrides=",">
            <if test="FID != null">
                #{FID},
            </if>
            <if test="AREANAME != null and AREANAME != ''">
                #{AREANAME},
            </if>
            <if test="AREAMEASURE != null">
                #{AREAMEASURE},
            </if>
            <if test="COLOR != null">
                #{COLOR},
            </if>
            <if test="ZVALUE != null">
                #{ZVALUE},
            </if>
        </trim>
 --       SET IDENTITY_INSERT SDE_AREA OFF
    </insert>
    <insert id="insertALL" parameterType="swzzmodeserver.workserver.pojo.swzzmode.SDE_AREAPojo">
        insert into SDE_AREA(FID,AREANAME,AREAMEASURE,COLOR,ZVALUE) values
        <foreach collection="objList" item="obj" separator=",">
            (#{obj.FID},#{obj.AREANAME},#{obj.AREAMEASURE},#{obj.COLOR},#{obj.ZVALUE})
        </foreach>
    </insert>
    <update id="updateOne" parameterType="swzzmodeserver.workserver.pojo.swzzmode.SDE_AREAPojo">
        update SDE_AREA
        <set>
            <if test="AREANAME != null and AREANAME != ''">
                AREANAME = #{AREANAME},
            </if>
            <if test="AREAMEASURE != null">
                AREAMEASURE = #{AREAMEASURE},
            </if>
            <if test="COLOR != null">
                COLOR = #{COLOR},
            </if>
            <if test="ZVALUE != null">
                ZVALUE = #{ZVALUE},
            </if>
        </set>
        where FID = #{FID}
    </update>
    <delete id="deleteOne">
        delete from SDE_AREA where FID = #{ID}
    </delete>
</mapper>