    <update id="updateALLSTATUS" parameterType="swzzmodeserver.workserver.pojo.swzzmode.ES_TIDALFORECASTPojo">
        <foreach collection="list" item="obj" separator=";">
            update ES_TIDALFORECAST
            <set>
                <if test="obj.STATUS != null and obj.STATUS != ''">
                    STATUS = #{obj.STATUS,jdbcType=VARCHAR},
                </if>
            </set>
            where YBTM = #{obj.YBTM,jdbcType=VARCHAR}
            and TM = #{obj.TM,jdbcType=VARCHAR}
            and FTM = #{obj.FTM,jdbcType=VARCHAR}
            and STCD= #{obj.STCD,jdbcType=VARCHAR}
        </foreach>
