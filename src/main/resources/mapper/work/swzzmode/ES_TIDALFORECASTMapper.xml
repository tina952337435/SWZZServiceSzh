    <insert id="insertALL" parameterType="swzzmodeserver.workserver.pojo.swzzmode.ES_TIDALFORECASTPojo">
        insert into "es_tidalforecast"(
        STCD,
        STNM,
        TM,
        YBTM,
        FTM,
        TDZ,
        ZS
        )
        values
        <foreach collection="objList" item="item" separator=",">
