            </if>
            <if test="YBTM != null and YBTM != ''">
                YBTM,
            </if>
            <if test="TDZ != null">
                TDZ,
            </if>
            <if test="ZS != null">
                ZS,
            </if>
            <if test="STATUS != null and STATUS != ''">
                STATUS,
            </if>
        </trim>
        values
        <trim prefix="(" suffix=")" suffixOverrides=",">
