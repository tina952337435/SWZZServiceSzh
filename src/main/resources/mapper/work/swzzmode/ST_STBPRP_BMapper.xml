    <select id="selectListBandStcd" resultType="swzzmodeserver.workserver.pojo.swzzmode.ST_STBPRP_BDto">
        select a.STCD,a.STNM,a.RVNM,a.HNNM,a.BSNM,a.LGTD,a.LTTD,a.XZDZ,b.ZSTCD,b.TYPE,a.LGTD84,a.LTTD84
        from "st_stbprp_b" a inner join "st_stbprp_b_stcd" b on a.STCD = b.STCD
        <where>
            <if test="stcd != null and stcd != ''">
                and a.STCD = #{stcd}
            </if>
        </where>
    </select>
    <select id="selectListBandStcdByStcdList" resultType="swzzmodeserver.workserver.pojo.swzzmode.ST_STBPRP_BDto">
        select a.STCD,a.STNM,a.RVNM,a.HNNM,a.BSNM,a.LGTD,a.LTTD,a.XZDZ,b.ZSTCD,b.TYPE,a.LGTD84,a.LTTD84
        from "st_stbprp_b" a inner join "st_stbprp_b_stcd" b on a.STCD = b.STCD
        <where>
            <if test="stcdList != null and stcdList.size() > 0">
                and (
                a.STCD in
                <foreach collection="stcdList" open="(" close=")" item="stcd" separator=",">
                    #{stcd}
                </foreach>
                or b.ZSTCD in
                <foreach collection="stcdList" open="(" close=")" item="stcd" separator=",">
                    #{stcd}
                </foreach>
                )
            </if>
        </where>
    </select>
