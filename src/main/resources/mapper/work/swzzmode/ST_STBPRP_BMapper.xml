    <select id="selectList" resultType="swzzmodeserver.workserver.pojo.swzzmode.ST_STBPRP_BPojo">
        select a.* from "st_stbprp_b" a
        <where>
            <if test="ID != null and ID != ''">
                and STCD = #{ID}
            </if>
            <if test="key != null and key != ''">
                and (
                STNM like concat('%',concat(#{key},'%'))
                or RVNM like concat('%',concat(#{key},'%'))
                or STLC like concat('%',concat(#{key},'%'))
                )
            </if>
            <if test="stime != null and stime != ''">
                <![CDATA[ and MODITIME >= #{stime} ]]>
            </if>
            <if test="etime != null and etime != ''">
                <![CDATA[ and MODITIME <= #{etime} ]]>
