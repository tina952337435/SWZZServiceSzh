                ID,
            </if>
            <if test="NAME != null and NAME != ''">
                NAME,
            </if>
            <if test="DD_TIME != null and DD_TIME != ''">
                DD_TIME,
            </if>
            <if test="YJ_TIME != null and YJ_TIME != ''">
                YJ_TIME,
            </if>
