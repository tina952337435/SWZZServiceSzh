            </if>
        </trim>
    </insert>
    <insert id="insertALL" parameterType="swzzmodeserver.workserver.pojo.swzzmode.SCHEME_TYPEPojo">
        insert into SCHEME_TYPE(ID,NAME,DD_TIME,YJ_TIME,NOTE) values
        <foreach collection="objList" item="obj" separator=",">
            (
            #{obj.ID},
            #{obj.NAME},
