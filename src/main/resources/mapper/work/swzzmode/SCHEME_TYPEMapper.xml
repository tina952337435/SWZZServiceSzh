            </if>
            <if test="stime != null and stime != ''">
                <![CDATA[ and YJ_TIME >= #{stime} ]]>
            </if>
            <if test="etime != null and etime != ''">
                <![CDATA[ and YJ_TIME <= #{etime} ]]>
            </if>
        </where>
        order by YJ_TIME desc
    </select>

