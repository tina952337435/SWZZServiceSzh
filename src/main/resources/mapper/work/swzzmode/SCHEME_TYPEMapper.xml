<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN" "http://mybatis.org/dtd/mybatis-3-mapper.dtd" >
<mapper namespace="swzzmodeserver.workserver.data.swzzmode.SCHEME_TYPEData">
    <select id="selectList" resultType="swzzmodeserver.workserver.pojo.swzzmode.SCHEME_TYPEPojo">
        select a.* from SCHEME_TYPE a
        <where>
            <if test="ID != null and ID != ''">
                and ID = #{ID}
            </if>
            <if test="key != null and key != ''">
                and (
                NAME like concat('%',concat(#{key},'%'))
                or NOTE like concat('%',concat(#{key},'%'))
                )
            </if>
            <if test="stime != null and stime != ''">
                <![CDATA[ and YJ_TIME >= #{stime} ]]>
            </if>
            <if test="etime != null and etime != ''">
                <![CDATA[ and YJ_TIME <= #{etime} ]]>
            </if>
            <if test="DDstime != null and DDstime != ''">
                <![CDATA[ and DD_TIME >= #{DDstime} ]]>
            </if>
            <if test="DDetime != null and DDetime != ''">
                <![CDATA[ and DD_TIME <= #{DDetime} ]]>
            </if>
        </where>
        <if test="startindex != null and pagesize != null">
            limit #{startindex},#{pagesize}
        </if>
        order by YJ_TIME desc
    </select>
    <select id="selectCount" resultType="java.lang.Integer">
        SELECT count(1) FROM SCHEME_TYPE
        <where>
            <if test="ID != null and ID != ''">
