    <update id="updateALLME" parameterType="list">
        MERGE INTO ES_ZHANDIANDATA t
        USING (
            <foreach collection="list" item="obj" separator="UNION ALL">
                SELECT 
                    #{obj.ZHANID, jdbcType=VARCHAR} AS ZHANID,
                    #{obj.ZHANTIME, jdbcType=VARCHAR} AS ZHANTIME,
                    #{obj.SOLUTIONID, jdbcType=VARCHAR} AS SOLUTIONID,
                    #{obj.ZHANDATA, jdbcType=VARCHAR} AS ZHANDATA
                FROM DUAL
            </foreach>
        ) s
        ON (t.ZHANID = s.ZHANID AND t.ZHANTIME = s.ZHANTIME AND t.SOLUTIONID = s.SOLUTIONID)
        WHEN MATCHED THEN
            UPDATE SET t.ZHANDATA = s.ZHANDATA
    </update>

