            <if test="enddate != null and enddate != ''">
                <![CDATA[ and ZHANTIME <= #{enddate} ]]>
            </if>
            <if test="SOLUTIONID != null and SOLUTIONID != ''">
                and SOLUTIONID = #{SOLUTIONID}
            </if>
            <if test="zhanid != null and zhanid.size() > 0">
                and ZHANID in
                <foreach collection="zhanid" open="(" close=")" item="id" separator=",">
                    #{id}
                </foreach>
            </if>
        </where>
