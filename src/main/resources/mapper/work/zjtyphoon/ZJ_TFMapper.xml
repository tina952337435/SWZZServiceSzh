    <select id="selectList" resultType="swzzmodeserver.workserver.pojo.zjtyphoon.ZJ_TFPojo">
        select A.* from ZJ_TF A
        <where>
            <if test="ID != null and ID != ''">
                and ZJ_ID = #{ID}
            </if>
            <if test="key != null and key != ''">
                and (
                ZJ_TFM like concat('%',concat(#{key},'%'))
                or ZJ_TFBH like concat('%',concat(#{key},'%'))
                )
            </if>
            <if test="stime != null and stime != ''">
                <![CDATA[ and ZJ_TFDATE >= #{stime} ]]>
            </if>
            <if test="etime != null and etime != ''">
                <![CDATA[ and ZJ_TFDATE <= #{etime} ]]>
            </if>
            <if test="type != null and type.size() > 0">
                and ZJ_ISCOMPLETED in
                <foreach collection="type" open="(" close=")" item="item" separator=",">
                    #{item}
                </foreach>
            </if>
            <if test="tfbhList != null and tfbhList.size() > 0">
                and ZJ_TFBH in
                <foreach collection="tfbhList" open="(" close=")" item="item" separator=",">
                    #{item}
                </foreach>
            </if>
        </where>
        <if test="startindex != null and pagesize != null">
            limit #{startindex},#{pagesize}
        </if>
    </select>


