            <if test="TFETIME != null and TFETIME !=''">
                #{TFETIME},
            </if>
            <if test="TFNOTE != null and TFNOTE != ''">
                #{TFNOTE},
            </if>
            <if test="TFXIANGSIDU != null">
                #{TFXIANGSIDU},
            </if>
            <if test="ISDEL != null and ISDEL != ''">
                #{ISDEL},
            </if>
        </trim>
    </insert>

    <update id="updateOne" parameterType="swzzmodeserver.workserver.pojo.zjtyphoon.ZJ_XSPojo">
        update ZJ_XS
        <set>
            <if test="TFSTIME != null and TFSTIME != ''">
                TFSTIME = #{TFSTIME},
            </if>
            <if test="TFETIME != null and TFETIME !=''">
                TFETIME = #{TFETIME},
            </if>
            <if test="TFNOTE != null and TFNOTE != ''">
                TFNOTE = #{TFNOTE},
            </if>
            <if test="TFXIANGSIDU != null">
                TFXIANGSIDU = #{TFXIANGSIDU},
            </if>
            <if test="ISDEL != null and ISDEL != ''">
                ISDEL = #{ISDEL},
            </if>
        </set>
        where PTFBH = #{PTFBH} and TFBH = #{TFBH} and TYPE = #{TYPE}
    </update>
    <delete id="deleteOne">
        delete from ZJ_XS where PTFBH = #{ID1} and TFBH = #{ID2} and TYPE = #{ID3}
    </delete>

    <insert id="insertALL" parameterType="list">
        insert into ZJ_XS
        (
        PTFBH,
        TFBH,
        TYPE,
        TFSTIME,
        TFETIME,
        TFNOTE,
        TFXIANGSIDU,
        ISDEL
        )
        values
        <foreach collection="objList" item="obj" separator=",">
            (
            #{obj.PTFBH},
            #{obj.TFBH},
            #{obj.TYPE},
            #{obj.TFSTIME},
            #{obj.TFETIME},
            #{obj.TFNOTE},
            #{obj.TFXIANGSIDU},
            #{obj.ISDEL}
            )
        </foreach>
    </insert>


    <update id="updateALL" parameterType="list">
        <foreach collection="objList" item="obj" separator=";">
            update ZJ_XS
            <set>
                <if test="obj.TFSTIME != null and obj.TFSTIME != ''">
                    TFSTIME = #{obj.TFSTIME},
                </if>
                <if test="obj.TFETIME != null and obj.TFETIME !=''">
                    TFETIME = #{obj.TFETIME},
                </if>
                <if test="obj.TFNOTE != null and obj.TFNOTE != ''">
                    TFNOTE = #{obj.TFNOTE},
                </if>
                <if test="obj.TFXIANGSIDU != null">
                    TFXIANGSIDU = #{obj.TFXIANGSIDU},
                </if>
                <if test="obj.ISDEL != null and obj.ISDEL != ''">
                    ISDEL = #{obj.ISDEL},
                </if>
            </set>
            where PTFBH = #{obj.PTFBH} and TFBH = #{obj.TFBH} and TYPE = #{obj.TYPE}
        </foreach>
    </update>

    <delete id="deleteALL">
        delete from ZJ_XS where
        <foreach collection="objList" item="obj" separator="or">
            ( PTFBH = #{obj.PTFBH} and TFBH = #{obj.TFBH} and TYPE = #{obj.TYPE} )
        </foreach>
