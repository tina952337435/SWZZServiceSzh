<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN" "http://mybatis.org/dtd/mybatis-3-mapper.dtd" >
<mapper namespace="swzzmodeserver.workserver.data.zjtyphoon.ZJ_XSData">
    <select id="selectList" resultType="swzzmodeserver.workserver.pojo.zjtyphoon.ZJ_XSPojo">
        select A.* from ZJ_XS A
        <where>
            <if test="ID != null and ID != ''">
                and PTFBH = #{ID}
            </if>
<!--            <if test="key != null and key != ''">-->
<!--                and (-->
<!--                info like concat('%',concat(#{key},'%'))-->
<!--                or landaddress like concat('%',concat(#{key},'%'))-->
<!--                or strong like concat('%',concat(#{key},'%'))-->
<!--                )-->
<!--            </if>-->
<!--            <if test="stime != null and stime != ''">-->
<!--                <![CDATA[ and landtime >= #{stime} ]]>-->
<!--            </if>-->
<!--            <if test="etime != null and etime != ''">-->
<!--                <![CDATA[ and landtime <= #{etime} ]]>-->
<!--            </if>-->
            <if test="type != null and type.size() > 0">
                and TYPE in
                <foreach collection="type" open="(" close=")" item="item" separator=",">
                    #{item}
                </foreach>
            </if>
        </where>
        <if test="startindex != null and pagesize != null">
            limit #{startindex},#{pagesize}
        </if>
    </select>

    <select id="selectCount" resultType="integer">
        SELECT count(1) FROM ZJ_XS
        <where>
            <if test="ID != null and ID != ''">
                and PTFBH = #{ID}
            </if>
        </where>
    </select>

    <insert id="insertOne" parameterType="swzzmodeserver.workserver.pojo.zjtyphoon.ZJ_XSPojo">
