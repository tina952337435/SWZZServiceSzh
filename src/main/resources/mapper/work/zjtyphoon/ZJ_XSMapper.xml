        <trim prefix="(" suffix=")" suffixOverrides=",">
            <if test="PTFBH != null">
                PTFBH,
            </if>
            <if test="TFBH != null">
                TFBH,
            </if>
            <if test="TYPE != null and TYPE != ''">
                TYPE,
            </if>
            <if test="TFSTIME != null and TFSTIME != ''">
                TFSTIME,
            </if>
            <if test="TFETIME != null and TFETIME !=''">
                TFETIME,
            </if>
            <if test="TFNOTE != null and TFNOTE != ''">
                TFNOTE,
            </if>
            <if test="TFXIANGSIDU != null">
                TFXIANGSIDU,
            </if>
            <if test="ISDEL != null and ISDEL != ''">
                ISDEL,
            </if>
        </trim>
        values
        <trim prefix="(" suffix=")" suffixOverrides=",">
            <if test="PTFBH != null">
                #{PTFBH},
            </if>
            <if test="TFBH != null">
                #{TFBH},
            </if>
            <if test="TYPE != null and TYPE != ''">
                #{TYPE},
